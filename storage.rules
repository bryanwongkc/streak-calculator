rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /games/{gameId}/rules/{fileName=**} {
      // MVP rule: anonymous-authenticated users can upload, read, and delete
      // rule images for games. Production should restrict this by game
      // membership and validate content type/size server-side.
      allow read, write: if request.auth != null;
    }
  }
}
